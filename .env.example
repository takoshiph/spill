# --- Supabase (client-side; safe to expose the ANON key, never the service key) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Resend (used ONLY by the Cloudflare Pages Function, server-side) ---
# Set these in the Cloudflare Pages dashboard as environment variables, NOT here.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_AUDIENCE_FROM=hello@yourdomain.com
